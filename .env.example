# Cloud dashboard environment variables (set these in the Vercel project).
#
# Provided automatically when you attach a Vercel Blob store to the project:
BLOB_READ_WRITE_TOKEN=

# Shared secret the robot sends as "Authorization: Bearer <token>" to /api/ingest.
# Must match FRONTIER_BENCHMARK_INGEST_TOKEN on the robot.
INGEST_TOKEN=change-me-long-random

# Single shared password to view the dashboard (HTTP Basic auth).
# Username is ignored; any username + this password works.
VIEWER_PASSWORD=change-me
